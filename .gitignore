# Dependencies (node_modules may be a symlink to node_modules.nosync on
# iCloud-synced folders — ignore both, plus iCloud "… 2" conflict copies)
node_modules
node_modules.nosync/
node_modules*/
*[0-9].nosync/

# Build output
dist/
dist-ssr/

# Logs
*.log
npm-debug.log*
steamdeals-launcher.log

# Editor / OS
.vscode/
.idea/
.claude/
.DS_Store
Thumbs.db

# Local env files
*.local
.env
.env.*

# Icon build intermediates
icon-work/

# Personal data — keep local, never commit (user's game lists, price-low
# history, and build notes)
Claude/

data/
